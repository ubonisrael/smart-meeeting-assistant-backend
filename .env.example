NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://smart_meeting:smart_meeting_password@localhost:5432/smart_meeting_assistant
REDIS_URL=redis://localhost:6379
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-session-secret
SESSION_COOKIE_NAME=smart_meeting_assistant.sid
SESSION_TTL_MS=2592000000
APP_URL=http://localhost:5173

# SMTP server email address (sender email)
# Type: string (valid email address)
# For Gmail: use your Gmail address or App Password
# Example: noreply@oravanti.com or your-email@gmail.com
SMTP_EMAIL_ADDRESS=noreply@oravanti.com

# SMTP server password (authentication for sending emails)
# Type: string
# For Gmail:
#   1. Enable 2-Step Verification on your Google account
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Use the 16-character password generated
# For other providers: use your email account password or application-specific password
# Example Gmail App Password: aabbccdd eeffgghh iijjkkll mmnnoopp (16 chars, no spaces)
# ⚠️ CRITICAL: Keep this secret - never commit to version control
SMTP_PASSWORD=aabbccddee_ffgghh_iijjkkll_mmnnoopp

SUPABASE_S3_ENDPOINT=https://your-project-id.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=your-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-secret-access-key
SUPABASE_STORAGE_BUCKET=meeting-recordings
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TRANSCRIPTION_MODEL=gemini-3.5-flash
